# Copy this file to .env and fill in your own values
# Never commit .env to git

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-random-secret-key-here

# Generate a 32-byte hex key: python -c "import secrets; print(secrets.token_hex(32))"
MASTER_ENCRYPTION_KEY=your-64-char-hex-key-here

# Your PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/securevault
